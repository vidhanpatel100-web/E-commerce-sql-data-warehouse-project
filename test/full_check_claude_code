/* =====================================================================
   3. ORDERS  (silver.arc_ord_info)
   ===================================================================== */
SELECT
    SUM(CASE WHEN order_id                        IS NULL THEN 1 ELSE 0 END) AS order_id_nulls,
    SUM(CASE WHEN customer_id                     IS NULL THEN 1 ELSE 0 END) AS customer_id_nulls,
    SUM(CASE WHEN order_status                    IS NULL THEN 1 ELSE 0 END) AS order_status_nulls,
    SUM(CASE WHEN order_purchase_timestamp        IS NULL THEN 1 ELSE 0 END) AS purchase_ts_nulls,
    SUM(CASE WHEN order_approved_at               IS NULL THEN 1 ELSE 0 END) AS approved_at_nulls,        -- may legitimately be null (e.g. cancelled)
    SUM(CASE WHEN order_delivered_carrier_date    IS NULL THEN 1 ELSE 0 END) AS delivered_carrier_nulls,  -- may legitimately be null
    SUM(CASE WHEN order_delivered_customer_date   IS NULL THEN 1 ELSE 0 END) AS delivered_customer_nulls, -- may legitimately be null
    SUM(CASE WHEN order_estimated_delivery_date   IS NULL THEN 1 ELSE 0 END) AS estimated_delivery_nulls
FROM silver.arc_ord_info;

SELECT
    COUNT(CASE WHEN LEN(CAST(order_id AS NVARCHAR(4000)))     != LEN(TRIM(CAST(order_id AS NVARCHAR(4000))))     THEN 1 END) AS order_id_has_spaces,
    COUNT(CASE WHEN LEN(CAST(customer_id AS NVARCHAR(4000)))  != LEN(TRIM(CAST(customer_id AS NVARCHAR(4000))))  THEN 1 END) AS customer_id_has_spaces,
    COUNT(CASE WHEN LEN(CAST(order_status AS NVARCHAR(4000))) != LEN(TRIM(CAST(order_status AS NVARCHAR(4000)))) THEN 1 END) AS order_status_has_spaces
FROM silver.arc_ord_info;


