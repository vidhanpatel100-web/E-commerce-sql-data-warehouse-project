/* =====================================================================
   SILVER LAYER — NULL & WHITESPACE VALIDATION (ALL TABLES)
   E-Commerce Data Warehouse | SQL Server
   =====================================================================
   Purpose:
     For every table loaded by silver.ecommerce_load_bronze, check:
       (a) NULL counts per column
       (b) Leading/trailing whitespace per column (values that differ
           from their own TRIM()'d version)

   Expectation for every query below: all counts = 0, unless a column
   is documented as allowed to be null (e.g. optional delivery dates).

   NOTE: silver.arc_ord_rvew_info is expected to return 0 rows entirely
   right now due to a bug in the load procedure (Section 6 inserts into
   the wrong table) — see accompanying notes. A 0-row result here is a
   symptom of that bug, not something this script itself needs to fix.
   ===================================================================== */


/* =====================================================================
   0. ROW COUNT OVERVIEW — quick sanity check before diving into detail
   ===================================================================== */
SELECT 'arc_cust_info'        AS table_name, COUNT(*) AS row_count FROM silver.arc_cust_info
UNION ALL
SELECT 'arc_geoloc_info',      COUNT(*) FROM silver.arc_geoloc_info
UNION ALL
SELECT 'arc_ord_info',         COUNT(*) FROM silver.arc_ord_info
UNION ALL
SELECT 'arc_ord_item_info',    COUNT(*) FROM silver.arc_ord_item_info
UNION ALL
SELECT 'arc_ord_rvew_info',    COUNT(*) FROM silver.arc_ord_rvew_info
UNION ALL
SELECT 'arc_prduct_info',      COUNT(*) FROM silver.arc_prduct_info
UNION ALL
SELECT 'arc_seler_info',       COUNT(*) FROM silver.arc_seler_info
UNION ALL
SELECT 'arc_prdt_ctr_nme_info',COUNT(*) FROM silver.arc_prdt_ctr_nme_info;


/* =====================================================================
   1. CUSTOMERS  (silver.arc_cust_info)
   ===================================================================== */
SELECT
    SUM(CASE WHEN customer_id               IS NULL THEN 1 ELSE 0 END) AS customer_id_nulls,
    SUM(CASE WHEN customer_unique_id        IS NULL THEN 1 ELSE 0 END) AS customer_unique_id_nulls,
    SUM(CASE WHEN customer_zip_code_prefix  IS NULL THEN 1 ELSE 0 END) AS zip_code_nulls,
    SUM(CASE WHEN customer_city             IS NULL THEN 1 ELSE 0 END) AS city_nulls,
    SUM(CASE WHEN customer_state            IS NULL THEN 1 ELSE 0 END) AS state_nulls
FROM silver.arc_cust_info;

SELECT
    COUNT(CASE WHEN LEN(CAST(customer_id AS NVARCHAR(4000)))        != LEN(TRIM(CAST(customer_id AS NVARCHAR(4000))))        THEN 1 END) AS customer_id_has_spaces,
    COUNT(CASE WHEN LEN(CAST(customer_unique_id AS NVARCHAR(4000))) != LEN(TRIM(CAST(customer_unique_id AS NVARCHAR(4000)))) THEN 1 END) AS customer_unique_id_has_spaces,
    COUNT(CASE WHEN LEN(CAST(customer_city AS NVARCHAR(4000)))      != LEN(TRIM(CAST(customer_city AS NVARCHAR(4000))))      THEN 1 END) AS customer_city_has_spaces,
    COUNT(CASE WHEN LEN(CAST(customer_state AS NVARCHAR(4000)))     != LEN(TRIM(CAST(customer_state AS NVARCHAR(4000))))     THEN 1 END) AS customer_state_has_spaces
FROM silver.arc_cust_info;


